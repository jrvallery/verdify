[Unit]
Description=Verdify Crop Catalog API
After=docker.service
Wants=docker.service

[Service]
Type=simple
User=jason
WorkingDirectory=/srv/verdify/api
EnvironmentFile=/srv/verdify/api/.env
ExecStart=/srv/greenhouse/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8300
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
