{
  "uid": "greenhouse-openclaw-ops",
  "title": "Greenhouse: OpenClaw Operations",
  "description": "AI agent interaction logging \u2014 calls, tokens, errors, latency",
  "tags": [
    "greenhouse",
    "openclaw",
    "operations",
    "standardized"
  ],
  "timezone": "America/Denver",
  "editable": false,
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "refresh": "5m",
  "templating": {
    "list": [
      {
        "name": "period",
        "type": "custom",
        "label": "Period",
        "current": {
          "text": "7d",
          "value": "7d"
        },
        "options": [
          {
            "text": "1d",
            "value": "1d",
            "selected": false
          },
          {
            "text": "7d",
            "value": "7d",
            "selected": true
          },
          {
            "text": "30d",
            "value": "30d",
            "selected": false
          }
        ],
        "query": "1d,7d,30d"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Calls",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) FROM openclaw_interaction_log WHERE ts > now() - '${period}'::interval",
          "refId": "A",
          "format": "table",
          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "custom": {}
        }
      },
      "options": {},
      "description": "Shows total OpenClaw tool or interaction calls in the selected period."
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Tokens",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "targets": [
        {
          "rawSql": "SELECT COALESCE(SUM(tokens_in + tokens_out), 0) FROM openclaw_interaction_log WHERE ts > now() - '${period}'::interval",
          "refId": "A",
          "format": "table",
          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          }
        }
      },
      "options": {},
      "description": "Shows total model tokens consumed in the selected period."
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error Rate",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "rawSql": "SELECT CASE WHEN COUNT(*) > 0 THEN ROUND(100.0 * COUNT(*) FILTER (WHERE NOT success) / COUNT(*), 1) ELSE 0 END AS pct FROM openclaw_interaction_log WHERE ts > now() - '${period}'::interval",
          "refId": "A",
          "format": "table",
          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          },
          "custom": {}
        }
      },
      "options": {},
      "description": "Shows the proportion of OpenClaw interactions that ended in error."
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Avg Duration",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "rawSql": "SELECT COALESCE(ROUND(AVG(duration_ms)::numeric, 0), 0) FROM openclaw_interaction_log WHERE ts > now() - '${period}'::interval",
          "refId": "A",
          "format": "table",
          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          }
        }
      },
      "options": {},
      "description": "Shows average runtime per OpenClaw interaction."
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Unique Actions",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 0
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(DISTINCT action) FROM openclaw_interaction_log WHERE ts > now() - '${period}'::interval",
          "refId": "A",
          "format": "table",
          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          }
        }
      },
      "options": {},
      "description": "Shows how many distinct OpenClaw actions were used."
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Models Used",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 0
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(DISTINCT model) FROM openclaw_interaction_log WHERE ts > now() - '${period}'::interval AND model IS NOT NULL",
          "refId": "A",
          "format": "table",
          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          }
        }
      },
      "options": {},
      "description": "Shows which models were used by OpenClaw in the selected period."
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Calls per Hour (by type)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "rawSql": "SELECT $__time(hour), session_type AS metric, calls AS value FROM v_openclaw_usage_hourly WHERE $__timeFilter(hour) ORDER BY hour",
          "refId": "A",
          "format": "time_series",
          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "stacking": {
              "mode": "normal"
            },
            "lineWidth": 2,
            "spanNulls": true
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "description": "Shows hourly OpenClaw activity split by call type."
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Token Usage per Day (stacked)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "rawSql": "SELECT $__time(day::timestamptz), session_type AS metric, total_tokens AS value FROM v_openclaw_usage_daily WHERE day > (CURRENT_DATE - '${period}'::interval) ORDER BY day",
          "refId": "A",
          "format": "time_series",
          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "stacking": {
              "mode": "normal"
            },
            "lineWidth": 2,
            "spanNulls": true
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "description": "Shows daily token usage split across OpenClaw activity types."
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Average Duration by Action",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "rawSql": "SELECT $__time(date_trunc('hour', ts)), action AS metric, ROUND(AVG(duration_ms)::numeric, 0) AS value FROM openclaw_interaction_log WHERE $__timeFilter(ts) AND duration_ms IS NOT NULL GROUP BY 1, 2 ORDER BY 1",
          "refId": "A",
          "format": "time_series",
          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "spanNulls": true
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "description": "Shows which OpenClaw actions take the longest on average."
    },
    {
      "id": 13,
      "type": "piechart",
      "title": "Calls by Session Type",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "targets": [
        {
          "rawSql": "SELECT session_type AS \"Type\", COUNT(*) AS \"Calls\" FROM openclaw_interaction_log WHERE ts > now() - '${period}'::interval GROUP BY 1 ORDER BY 2 DESC",
          "refId": "A",
          "format": "table",
          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {}
        }
      },
      "options": {},
      "description": "Shows how OpenClaw usage is distributed across session types."
    },
    {
      "id": 20,
      "type": "table",
      "title": "Recent Errors",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "targets": [
        {
          "rawSql": "SELECT ts AT TIME ZONE 'America/Denver' AS \"Time\", session_type AS \"Type\", action AS \"Action\", model AS \"Model\", duration_ms AS \"Duration (ms)\", error_message AS \"Error\" FROM openclaw_interaction_log WHERE NOT success AND ts > now() - '${period}'::interval ORDER BY ts DESC LIMIT 50",
          "refId": "A",
          "format": "table",
          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "No errors in this period",
          "custom": {}
        }
      },
      "options": {
        "showHeader": true
      },
      "description": "Shows the most recent OpenClaw errors for debugging and reliability review."
    }
  ],
  "annotations": {
    "list": []
  }
}