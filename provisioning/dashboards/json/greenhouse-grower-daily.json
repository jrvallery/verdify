          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "verdify-tsdb"
          },
          "format": "table",
          "rawSql": "SELECT task, COALESCE(zone, 'all') AS zone, priority, frequency,\n  CASE WHEN completed_at IS NOT NULL THEN 'Yes' ELSE '' END AS done,\n  to_char(completed_at, 'HH:MI AM') AS completed\nFROM v_daily_checklist\nORDER BY (completed_at IS NOT NULL), priority, zone NULLS LAST",
