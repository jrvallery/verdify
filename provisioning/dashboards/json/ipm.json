{
  "uid": "greenhouse-ipm",
  "title": "Greenhouse: IPM & Disease Risk",
  "description": "Integrated Pest Management \u2014 disease risk scoring, environmental conditions for pathogen pressure, treatment tracking",
  "tags": [
    "greenhouse",
    "ipm",
    "persona",
    "standardized"
  ],
  "timezone": "browser",
  "editable": false,
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "refresh": "5m",
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Disease Risk Overview",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 10,
      "type": "gauge",
      "title": "Botrytis Risk (current)",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "rawSql": "SELECT botrytis_risk_pct AS \"Botrytis %\" FROM v_disease_risk ORDER BY hour DESC LIMIT 1",
          "refId": "A",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 30
              },
              {
                "color": "orange",
                "value": 60
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          },
          "custom": {}
        }
      },
      "description": "Shows current or recent botrytis disease risk based on greenhouse conditions.",
      "options": {}
    },
    {
      "id": 11,
      "type": "gauge",
      "title": "Condensation Risk (current)",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "targets": [
        {
          "rawSql": "SELECT condensation_risk_pct AS \"Condensation %\" FROM v_disease_risk ORDER BY hour DESC LIMIT 1",
          "refId": "A",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 30
              },
              {
                "color": "orange",
                "value": 60
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          },
          "custom": {}
        }
      },
      "description": "Shows current or recent condensation risk based on greenhouse conditions.",
      "options": {}
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Consecutive High-Risk Hours (Botrytis)",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "rawSql": "SELECT MAX(botrytis_consecutive_hours) AS \"Hours\" FROM v_disease_risk WHERE hour > now() - interval '24 hours'",
          "refId": "A",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 4
              },
              {
                "color": "red",
                "value": 8
              }
            ]
          },
          "custom": {}
        }
      },
      "description": "Shows how many consecutive hours conditions stayed in a botrytis-risk state.",
      "options": {}
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Consecutive High-Risk Hours (Condensation)",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "targets": [
        {
          "rawSql": "SELECT MAX(condensation_consecutive_hours) AS \"Hours\" FROM v_disease_risk WHERE hour > now() - interval '24 hours'",
          "refId": "A",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 4
              },
              {
                "color": "red",
                "value": 8
              }
            ]
          },
          "custom": {}
        }
      },
      "description": "Shows how many consecutive hours conditions stayed in a condensation-risk state.",
      "options": {}
    },
    {
      "id": 2,
      "type": "row",
      "title": "Disease Risk Trends",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 7
      }
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Botrytis Risk (hourly)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "rawSql": "SELECT $__time(hour), botrytis_risk_pct AS \"Botrytis Risk %\" FROM v_disease_risk WHERE $__timeFilter(hour) ORDER BY hour",
          "refId": "A",
          "format": "time_series"
        },
        {
          "rawSql": "SELECT $__time(hour), botrytis_consecutive_hours AS \"Consecutive Hours\" FROM v_disease_risk WHERE $__timeFilter(hour) ORDER BY hour",
          "refId": "B",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Consecutive Hours"
            },
            "properties": [
              {
                "id": "custom.axisPlacement",
                "value": "right"
              },
              {
                "id": "unit",
                "value": "h"
              }
            ]
          }
        ]
      },
      "description": "Shows current or recent botrytis disease risk based on greenhouse conditions.",
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "min",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Condensation Risk (hourly)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "rawSql": "SELECT $__time(hour), condensation_risk_pct AS \"Condensation Risk %\" FROM v_disease_risk WHERE $__timeFilter(hour) ORDER BY hour",
          "refId": "A",
          "format": "time_series"
        },
        {
          "rawSql": "SELECT $__time(hour), condensation_consecutive_hours AS \"Consecutive Hours\" FROM v_disease_risk WHERE $__timeFilter(hour) ORDER BY hour",
          "refId": "B",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Consecutive Hours"
            },
            "properties": [
              {
                "id": "custom.axisPlacement",
                "value": "right"
              },
              {
                "id": "unit",
                "value": "h"
              }
            ]
          }
        ]
      },
      "description": "Shows current or recent condensation risk based on greenhouse conditions.",
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "min",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 3,
      "type": "row",
      "title": "Environmental Conditions (Disease Drivers)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 16
      }
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "Humidity & Dew Point (disease drivers)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 17
      },
      "targets": [
        {
          "rawSql": "SELECT $__time(ts), rh_avg AS \"RH %\" FROM climate WHERE $__timeFilter(ts) AND rh_avg IS NOT NULL ORDER BY ts",
          "refId": "A",
          "format": "time_series"
        },
        {
          "rawSql": "SELECT $__time(ts), dew_point AS \"Dew Point (\u00b0F)\" FROM climate WHERE $__timeFilter(ts) AND dew_point IS NOT NULL ORDER BY ts",
          "refId": "B",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Dew Point (\u00b0F)"
            },
            "properties": [
              {
                "id": "custom.axisPlacement",
                "value": "right"
              },
              {
                "id": "unit",
                "value": "\u00b0F"
              }
            ]
          }
        ],
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "description": "Shows humidity and dew point conditions that drive disease pressure.",
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "min",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Temperature & VPD (pathogen pressure)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 17
      },
      "targets": [
        {
          "rawSql": "SELECT $__time(ts), temp_avg AS \"Temp (\u00b0F)\" FROM climate WHERE $__timeFilter(ts) AND temp_avg IS NOT NULL ORDER BY ts",
          "refId": "A",
          "format": "time_series"
        },
        {
          "rawSql": "SELECT $__time(ts), vpd_avg AS \"VPD (kPa)\" FROM climate WHERE $__timeFilter(ts) AND vpd_avg IS NOT NULL ORDER BY ts",
          "refId": "B",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "VPD (kPa)"
            },
            "properties": [
              {
                "id": "custom.axisPlacement",
                "value": "right"
              }
            ]
          }
        ],
        "defaults": {
          "unit": "fahrenheit",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "description": "Shows temperature and VPD conditions relevant to pathogen pressure.",
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "min",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 4,
      "type": "row",
      "title": "Zone Humidity Comparison",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 25
      }
    },
    {
      "id": 40,
      "type": "timeseries",
      "title": "Zone RH (disease pocket detection)",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 26
      },
      "targets": [
        {
          "rawSql": "SELECT $__time(ts), rh_north AS \"North\" FROM climate WHERE $__timeFilter(ts) AND rh_north IS NOT NULL ORDER BY ts",
          "refId": "A",
          "format": "time_series"
        },
        {
          "rawSql": "SELECT $__time(ts), rh_south AS \"South\" FROM climate WHERE $__timeFilter(ts) AND rh_south IS NOT NULL ORDER BY ts",
          "refId": "B",
          "format": "time_series"
        },
        {
          "rawSql": "SELECT $__time(ts), rh_east AS \"East\" FROM climate WHERE $__timeFilter(ts) AND rh_east IS NOT NULL ORDER BY ts",
          "refId": "C",
          "format": "time_series"
        },
        {
          "rawSql": "SELECT $__time(ts), rh_west AS \"West\" FROM climate WHERE $__timeFilter(ts) AND rh_west IS NOT NULL ORDER BY ts",
          "refId": "D",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "description": "Shows relative humidity by zone to reveal localized disease pockets.",
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "min",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 5,
      "type": "row",
      "title": "Treatment & Observation Log",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 34
      }
    },
    {
      "id": 50,
      "type": "table",
      "title": "Recent Treatments",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 35
      },
      "targets": [
        {
          "rawSql": "SELECT ts AT TIME ZONE 'America/Denver' AS \"Date\", crop_id, product, target_pest, phi_days, rei_hours, notes FROM treatments WHERE ts > now() - interval '90 days' ORDER BY ts DESC LIMIT 20",
          "refId": "A",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "No treatments recorded",
          "custom": {}
        }
      },
      "description": "Shows the most recent plant treatments or interventions.",
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 51,
      "type": "table",
      "title": "Recent Observations",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 35
      },
      "targets": [
        {
          "rawSql": "SELECT ts AT TIME ZONE 'America/Denver' AS \"Date\", crop_id, category, severity, notes FROM observations WHERE ts > now() - interval '90 days' ORDER BY ts DESC LIMIT 20",
          "refId": "A",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "No observations recorded",
          "custom": {}
        }
      },
      "description": "Shows the most recent greenhouse observations logged into the system.",
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 6,
      "type": "row",
      "title": "Fog & Ventilation (pathogen management)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 41
      }
    },
    {
      "id": 60,
      "type": "timeseries",
      "title": "Fog Runtime vs RH",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 42
      },
      "targets": [
        {
          "rawSql": "SELECT $__time(date::timestamptz), runtime_fog_min AS \"Fog (min)\" FROM daily_summary WHERE $__timeFilter(date::timestamptz) ORDER BY date",
          "refId": "A",
          "format": "time_series"
        },
        {
          "rawSql": "SELECT $__time(ts), rh_avg AS \"RH %\" FROM climate WHERE $__timeFilter(ts) AND rh_avg IS NOT NULL ORDER BY ts",
          "refId": "B",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "RH %"
            },
            "properties": [
              {
                "id": "custom.axisPlacement",
                "value": "right"
              }
            ]
          }
        ],
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "description": "Shows fog runtime against relative humidity response.",
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "min",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 61,
      "type": "timeseries",
      "title": "Ventilation Runtime (air exchange)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 42
      },
      "targets": [
        {
          "rawSql": "SELECT $__time(date::timestamptz), runtime_vent_min AS \"Vent (min)\" FROM daily_summary WHERE $__timeFilter(date::timestamptz) ORDER BY date",
          "refId": "A",
          "format": "time_series"
        },
        {
          "rawSql": "SELECT $__time(date::timestamptz), runtime_fan1_min + runtime_fan2_min AS \"Fans (min)\" FROM daily_summary WHERE $__timeFilter(date::timestamptz) ORDER BY date",
          "refId": "B",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "min",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 40,
            "lineWidth": 2
          }
        }
      },
      "description": "Shows ventilation runtime as a proxy for air exchange activity.",
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "min",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    }
  ],
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  }
