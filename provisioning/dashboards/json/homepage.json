          "rawSql": "SELECT time_bucket_gapfill('1 hour', ts, start => $__timeFrom(), finish => now()) AS time, locf(last(value, ts)) AS \"Target High\" FROM setpoint_changes WHERE parameter = 'vpd_high' AND value > 0.1 AND ts BETWEEN now() - interval '3 days' AND now() GROUP BY 1 ORDER BY 1"
