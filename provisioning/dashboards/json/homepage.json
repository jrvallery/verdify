      "targets": [
        {
          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          },
          "format": "time_series",
          "refId": "A",
          "rawSql": "SELECT $__time(ts), temp_avg AS \"Interior\" FROM climate WHERE $__timeFilter(ts) AND ts <= now() AND temp_avg IS NOT NULL ORDER BY ts"
        },
        {
          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          },
          "format": "time_series",
          "refId": "B",
          "rawSql": "SELECT $__time(ts), outdoor_temp_f AS \"Outdoor\" FROM climate WHERE $__timeFilter(ts) AND ts <= now() AND outdoor_temp_f IS NOT NULL ORDER BY ts"
        },
        {
          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          },
          "format": "time_series",
          "refId": "C",
          "rawSql": "SELECT $__time(ts), temp_f AS \"Forecast\" FROM (SELECT DISTINCT ON (ts) ts, temp_f FROM weather_forecast WHERE ts > now() AND $__timeFilter(ts) ORDER BY ts, fetched_at DESC) sub ORDER BY ts"
        },
        {
          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          },
          "format": "time_series",
          "refId": "D",
          "rawSql": "SELECT time_bucket_gapfill('1 hour', ts, start => $__timeFrom(), finish => now()) AS time, locf(last(value, ts)) AS \"Target High\" FROM setpoint_changes WHERE parameter = 'temp_high' AND value > 0 AND ts BETWEEN now() - interval '3 days' AND now() GROUP BY 1 ORDER BY 1"
        },
        {
          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          },
          "format": "time_series",
          "refId": "E",
          "rawSql": "SELECT time_bucket_gapfill('1 hour', ts, start => $__timeFrom(), finish => now()) AS time, locf(last(value, ts)) AS \"Target Low\" FROM setpoint_changes WHERE parameter = 'temp_low' AND value > 0 AND ts BETWEEN now() - interval '3 days' AND now() GROUP BY 1 ORDER BY 1"
        },
        {
          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          },
          "format": "time_series",
          "refId": "F",
          "rawSql": "SELECT ts AS time, value AS \"Plan High\" FROM v_setpoint_forward WHERE parameter = 'temp_high' AND $__timeFilter(ts) ORDER BY ts"
        },
        {
          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          },
          "format": "time_series",
          "refId": "G",
          "rawSql": "SELECT ts AS time, value AS \"Plan Low\" FROM v_setpoint_forward WHERE parameter = 'temp_low' AND $__timeFilter(ts) ORDER BY ts"
        }
      ],
      "title": "Temperature",
      "type": "timeseries",
      "description": "Shows temperature conditions for the greenhouse."
    },
