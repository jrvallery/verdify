# Verdify Environment Configuration
# Copy to .env and fill in your values. Also copy to ingestor/.env and api/.env.

# ── Database ──────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=verdify
# DB_USER=verdify

# ── Grafana ──────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=change_me

# ── ESP32 ─────────────────────────────────────────────────────────
# ESP32_HOST=192.168.10.111
# ESP32_PORT=6053
# ESP32_API_KEY=your_noise_psk_base64

# ── Home Assistant ───────────────────────────────────────────────
# HA_URL=http://192.168.30.107:8123
# HA_TOKEN_FILE=/path/to/credentials/ha_token.txt

# ── MQTT (Sentinel occupancy) ───────────────────────────────────
# MQTT_HOST=192.168.30.107
# MQTT_PORT=1883
# MQTT_USER=home
# MQTT_PASS=change_me

# ── Slack ────────────────────────────────────────────────────────
# SLACK_TOKEN_FILE=/path/to/credentials/slack_bot_token.txt
# SLACK_CHANNEL=C0ANVVAPLD6

# ── Gemini AI ────────────────────────────────────────────────────
# GEMINI_API_KEY_FILE=/path/to/credentials/gemini_api_key.txt

# ── External services ───────────────────────────────────────────
# FRIGATE_URL=http://192.168.30.142:5000
# LOKI_URL=

# ── API write/admin access ──────────────────────────────────────
# Required for protected operator endpoints such as contact notification retry.
# VERDIFY_WRITE_API_KEY=change_me
# VERDIFY_ALLOW_UNAUTHENTICATED_WRITES=false

# ── Public contact notifications ────────────────────────────────
# Contact form submissions are always stored in Postgres first. Configure
# these to also send a private email notification from the API container.
# VERDIFY_CONTACT_NOTIFY_TO=jason@example.com
# VERDIFY_CONTACT_NOTIFY_FROM=contact@example.com
# VERDIFY_CONTACT_NOTIFY_FROM_NAME=Verdify Contact
# VERDIFY_CONTACT_NOTIFY_SUBJECT_PREFIX=Verdify contact
# VERDIFY_CONTACT_SMTP_HOST=smtp.example.com
# VERDIFY_CONTACT_SMTP_PORT=587
# VERDIFY_CONTACT_SMTP_USERNAME=contact@example.com
# VERDIFY_CONTACT_SMTP_PASSWORD=change_me
# VERDIFY_CONTACT_SMTP_STARTTLS=true
# VERDIFY_CONTACT_SMTP_SSL=false
# VERDIFY_CONTACT_SMTP_TIMEOUT_S=6

# ── Greenhouse ───────────────────────────────────────────────────
# GREENHOUSE_ID=vallery
# LATITUDE=40.1672
# LONGITUDE=-105.1019
# TZ=America/Denver

# ── Utility rates ────────────────────────────────────────────────
# ELECTRIC_RATE=0.111
# GAS_RATE=0.83
# WATER_RATE=0.00484
