# === Verdify Production Environment Example ===
# Copy to a secure location on the swarm manager as: /opt/verdify/.env (not committed)
# Fill placeholders. Do NOT commit the real .env.

PROJECT_NAME=Verdify
STACK_NAME=verdify

# Base domain where subdomains will be created
DOMAIN=example.com
FRONTEND_HOST=https://dashboard.example.com
ENVIRONMENT=production
BACKEND_CORS_ORIGINS=["https://dashboard.example.com"]

# PostgreSQL
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=verdify
POSTGRES_DB=verdify
# Secrets below can be injected via .env OR via swarm secrets (recommended)
POSTGRES_PASSWORD=__REPLACE_OR_USE_SECRET__

# Application bootstrap superuser
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=__REPLACE_OR_USE_SECRET__

# Security
SECRET_KEY=__REPLACE_OR_USE_SECRET__

# Email (optional)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_TLS=true
SMTP_SSL=false
SMTP_USER=apikey
SMTP_PASSWORD=__REPLACE_OR_USE_SECRET__
EMAILS_FROM_EMAIL=verdify@example.com
# EMAILS_FROM_NAME overrides display name (optional)
# EMAILS_FROM_NAME=Verdify

# Observability
SENTRY_DSN=

# Docker images (built by GitHub Actions)
DOCKER_IMAGE_BACKEND=ghcr.io/jvallery/verdify-backend
DOCKER_IMAGE_FRONTEND=ghcr.io/jvallery/verdify-frontend
# TAG set to 'latest' for prod auto-updates; can pin to a commit SHA for rollback
TAG=latest

# Optional additional CORS origins (JSON list)
# BACKEND_CORS_ORIGINS=["https://dashboard.example.com","https://extra.example.com"]
