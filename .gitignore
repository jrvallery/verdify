# Runtime state — local filesystem (write-heavy, service-critical)
# Both directory and symlink forms are ignored because /srv/verdify/state
# and /srv/verdify/reports became symlinks to /var/local/verdify/ on
# 2026-04-18 to keep services available during NFS stalls.
state/
state
logs/
*.log

# Grafana
grafana/data/

# Backups
*.dump
*.bak

# Archived / deprecated
archive/

# Quartz site (separate build, too large for main repo)
verdify-site/
site/public

# OS
.DS_Store
reports/
reports
firmware/test/replay_overrides
firmware/artifacts/

# Claude Code local settings — per-worktree, never committed
.claude/settings.local.json
