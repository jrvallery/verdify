          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          },
          "rawSql": "SELECT now() AS time, COALESCE(ROUND(AVG(cost_total)::numeric, 2), 0) AS v FROM daily_summary WHERE $__timeFilter((date + time '12:00')::timestamptz) AND cost_total > 0",
