{
  "uid": "greenhouse-irrigation",
  "title": "Greenhouse: Irrigation & Water",
  "description": "Water usage, drip schedules, mister effectiveness, VPD-driven irrigation",
  "tags": [
    "greenhouse",
    "irrigation",
    "new",
    "persona",
    "review",
    "standardized",
    "story-graphs"
  ],
  "timezone": "browser",
  "editable": false,
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "refresh": "5m",
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Water Overview",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "custom": {}
        }
      },
      "options": {}
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Water Today (gal)",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "rawSql": "SELECT used_gal AS \"Gallons\" FROM v_water_daily WHERE day = CURRENT_DATE ORDER BY day DESC LIMIT 1",
          "refId": "A",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "gal",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 100
              },
              {
                "color": "red",
                "value": 200
              }
            ]
          },
          "custom": {}
        },
        "overrides": []
      },
      "options": {},
      "description": "Shows water use or irrigation behavior over time."
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Mister Water Today (gal)",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "targets": [
        {
          "rawSql": "SELECT mister_water_today AS \"Mister\" FROM climate WHERE mister_water_today IS NOT NULL ORDER BY ts DESC LIMIT 1",
          "refId": "A",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "gal",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 30
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          },
          "custom": {}
        },
        "overrides": []
      },
      "options": {},
      "description": "Shows water use or irrigation behavior over time."
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Water Cost Today ($)",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "targets": [
        {
          "rawSql": "SELECT cost_water FROM v_cost_today",
          "refId": "A",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "custom": {},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {},
      "description": "Shows operating cost behavior for this part of the greenhouse system."
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Drip Wall Last Run",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "rawSql": "SELECT to_char(ts AT TIME ZONE 'America/Denver', 'MM/DD HH:MI AM') AS \"Last Run\" FROM equipment_state WHERE equipment = 'drip_wall' AND state = true ORDER BY ts DESC LIMIT 1",
          "refId": "A",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "custom": {}
        },
        "overrides": []
      },
      "options": {},
      "description": "Shows when the wall drip zone last ran."
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Drip Center Last Run",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 1
      },
      "targets": [
        {
          "rawSql": "SELECT to_char(ts AT TIME ZONE 'America/Denver', 'MM/DD HH:MI AM') AS \"Last Run\" FROM equipment_state WHERE equipment = 'drip_center' AND state = true ORDER BY ts DESC LIMIT 1",
          "refId": "A",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "custom": {}
        },
        "overrides": []
      },
      "options": {},
      "description": "Shows when the center drip zone last ran."
    },
    {
      "id": 15,
      "type": "stat",
      "title": "Flow Rate (GPM)",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 1
      },
      "targets": [
        {
          "rawSql": "SELECT flow_gpm AS \"GPM\" FROM climate WHERE flow_gpm IS NOT NULL ORDER BY ts DESC LIMIT 1",
          "refId": "A",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "gal/min",
          "decimals": 2,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "blue",
                "value": 0.05
              }
            ]
          },
          "custom": {}
        },
        "overrides": []
      },
      "options": {},
      "description": "Shows current or recent irrigation flow rate in gallons per minute."
    },
    {
      "id": 2,
      "type": "row",
      "title": "Water Usage Trends",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "fieldConfig": {
        "defaults": {
          "custom": {}
        }
      },
      "options": {}
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Daily Water Usage (7 days)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "targets": [
        {
          "rawSql": "SELECT $__time(day::timestamptz), used_gal AS \"Total Water (gal)\" FROM v_water_daily WHERE $__timeFilter(day::timestamptz) ORDER BY day",
          "refId": "A",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "gal",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 15,
            "lineWidth": 2,
            "spanNulls": true,
            "lineInterpolation": "linear",
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "calcs": [
            "lastNotNull",
            "min",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "description": "Shows water use or irrigation behavior over time."
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Mister Water + Flow Rate",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "targets": [
        {
          "rawSql": "SELECT $__time(ts), mister_water_today AS \"Mister Cumulative (gal)\" FROM climate WHERE $__timeFilter(ts) AND mister_water_today IS NOT NULL ORDER BY ts",
          "refId": "A",
          "format": "time_series"
        },
        {
          "rawSql": "SELECT $__time(ts), flow_gpm AS \"Flow Rate (GPM)\" FROM climate WHERE $__timeFilter(ts) AND flow_gpm IS NOT NULL ORDER BY ts",
          "refId": "B",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Flow Rate (GPM)"
            },
            "properties": [
              {
                "id": "custom.axisPlacement",
                "value": "right"
              }
            ]
          }
        ],
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "spanNulls": true,
            "lineInterpolation": "linear",
            "showPoints": "never",
            "fillOpacity": 10
          },
          "unit": "gal"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "calcs": [
            "lastNotNull",
            "min",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "description": "Shows water use or irrigation behavior over time."
    },
    {
      "id": 3,
      "type": "row",
      "title": "Mister Performance",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "fieldConfig": {
        "defaults": {
          "custom": {}
        }
      },
      "options": {}
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "Mister Zone Runtimes (daily)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 15
      },
      "targets": [
        {
          "rawSql": "SELECT $__time(date::timestamptz), runtime_mister_south_h * 60 AS \"South (min)\" FROM daily_summary WHERE $__timeFilter(date::timestamptz) AND runtime_mister_south_h > 0 ORDER BY date",
          "refId": "A",
          "format": "time_series"
        },
        {
          "rawSql": "SELECT $__time(date::timestamptz), runtime_mister_west_h * 60 AS \"West (min)\" FROM daily_summary WHERE $__timeFilter(date::timestamptz) AND runtime_mister_west_h > 0 ORDER BY date",
          "refId": "B",
          "format": "time_series"
        },
        {
          "rawSql": "SELECT $__time(date::timestamptz), runtime_mister_center_h * 60 AS \"Center (min)\" FROM daily_summary WHERE $__timeFilter(date::timestamptz) AND runtime_mister_center_h > 0 ORDER BY date",
          "refId": "C",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "min",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 15,
            "stacking": {
              "mode": "normal"
            },
            "lineWidth": 2,
            "spanNulls": true,
            "lineInterpolation": "linear",
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "calcs": [
            "lastNotNull",
            "min",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "description": "Shows daily runtime totals for the misting zones."
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Drip Runtimes (daily)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 15
      },
      "targets": [
        {
          "rawSql": "SELECT $__time(date::timestamptz), runtime_drip_wall_h * 60 AS \"Wall Drip (min)\" FROM daily_summary WHERE $__timeFilter(date::timestamptz) AND runtime_drip_wall_h > 0 ORDER BY date",
          "refId": "A",
          "format": "time_series"
        },
        {
          "rawSql": "SELECT $__time(date::timestamptz), runtime_drip_center_h * 60 AS \"Center Drip (min)\" FROM daily_summary WHERE $__timeFilter(date::timestamptz) AND runtime_drip_center_h > 0 ORDER BY date",
          "refId": "B",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "min",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 15,
            "lineWidth": 2,
            "spanNulls": true,
            "lineInterpolation": "linear",
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "calcs": [
            "lastNotNull",
            "min",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "description": "Shows daily runtime totals for the drip zones."
    },
    {
      "id": 4,
