    {
      "id": 40,
      "type": "timeseries",
      "title": "VPD vs Mister Activity",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "rawSql": "SELECT $__time(ts), vpd_avg AS \"VPD (kPa)\" FROM climate WHERE $__timeFilter(ts) AND vpd_avg IS NOT NULL ORDER BY ts",
          "refId": "A",
          "format": "time_series"
        },
        {
          "rawSql": "SELECT $__time(ts), CASE WHEN state THEN 1 ELSE 0 END AS \"Mister South\" FROM equipment_state WHERE $__timeFilter(ts) AND equipment = 'mister_south' ORDER BY ts",
          "refId": "B",
          "format": "time_series"
        },
        {
          "rawSql": "SELECT $__time(ts), CASE WHEN state THEN 1 ELSE 0 END AS \"Mister West\" FROM equipment_state WHERE $__timeFilter(ts) AND equipment = 'mister_west' ORDER BY ts",
          "refId": "C",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Mister South"
            },
            "properties": [
              {
                "id": "custom.axisPlacement",
                "value": "right"
              },
              {
                "id": "custom.fillOpacity",
                "value": 30
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Mister West"
            },
            "properties": [
              {
                "id": "custom.axisPlacement",
                "value": "right"
              },
              {
                "id": "custom.fillOpacity",
                "value": 30
              }
            ]
          }
        ],
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "spanNulls": true,
            "lineInterpolation": "linear",
            "showPoints": "never",
            "fillOpacity": 10,
            "axisLabel": "kPa"
          },
          "unit": "pressurekpa"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "calcs": [
            "lastNotNull",
            "min",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "description": "Shows vapor pressure deficit over time, one of the most important plant-stress signals in the greenhouse."
    },
