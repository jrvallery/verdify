    {
      "id": 51,
      "type": "table",
      "title": "Irrigation Event Log (24h)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 33
      },
      "targets": [
        {
          "rawSql": "SELECT ts AT TIME ZONE 'America/Denver' AS \"Time\", equipment AS \"Zone\", CASE WHEN state THEN 'ON' ELSE 'OFF' END AS \"State\" FROM equipment_state WHERE equipment IN ('drip_wall', 'drip_center', 'drip_wall_fert', 'drip_center_fert', 'mister_south', 'mister_west', 'mister_center') AND ts > now() - interval '24 hours' ORDER BY ts DESC LIMIT 50",
          "refId": "A",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {}
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      },
      "description": "Shows water use or irrigation behavior over time."
    },
