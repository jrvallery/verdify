          "rawSql": "SELECT time_bucket('5 minutes', ts) AS time, avg(soil_moisture_south_1) AS \"South 1 (Canna)\", avg(soil_moisture_south_2) AS \"South 2 (Canna)\", avg(soil_moisture_west) AS \"West\" FROM climate WHERE $__timeFilter(ts) AND (soil_moisture_south_1 IS NOT NULL OR soil_moisture_south_2 IS NOT NULL OR soil_moisture_west IS NOT NULL) GROUP BY 1 ORDER BY 1"
