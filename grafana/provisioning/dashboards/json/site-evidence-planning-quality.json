    {
      "id": 11,
      "type": "timeseries",
      "title": "Forecast vs Planned vs Actual — Temperature",
      "description": "Shows whether the plan anticipated forecast pressure and whether actual indoor temperature stayed inside the intended band.",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "verdify-tsdb"
      },
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "verdify-tsdb"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT f.ts AS time, f.temp_f AS \"Forecast Outdoor Temp\" FROM weather_forecast f WHERE f.ts > now() - interval '72 hours' AND f.ts < now() + interval '24 hours' ORDER BY 1",
          "editorMode": "code"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "verdify-tsdb"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT c.ts AS time, avg(c.temp_avg) OVER (ORDER BY c.ts ROWS BETWEEN 14 PRECEDING AND CURRENT ROW) AS \"Actual Indoor Temp\" FROM climate c WHERE c.ts > now() - interval '72 hours' ORDER BY 1",
          "editorMode": "code"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "verdify-tsdb"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT sp.ts AS time, sp.value AS \"Planned temp_high\" FROM setpoint_plan sp WHERE sp.parameter='temp_high' AND sp.ts > now() - interval '72 hours' ORDER BY 1",
          "editorMode": "code"
        },
        {
          "refId": "D",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "verdify-tsdb"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT sp.ts AS time, sp.value AS \"Planned temp_low\" FROM setpoint_plan sp WHERE sp.parameter='temp_low' AND sp.ts > now() - interval '72 hours' ORDER BY 1",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "fahrenheit",
