              },
              {
                "id": "unit",
                "value": "\u00b5S/cm"
              },
              {
                "id": "custom.axisPlacement",
                "value": "left"
              },
              {
                "id": "custom.fillOpacity",
                "value": 10
              },
              {
                "id": "custom.gradientMode",
                "value": "opacity"
              },
              {
                "id": "custom.thresholdsStyle",
                "value": {
                  "mode": "area"
                }
              },
