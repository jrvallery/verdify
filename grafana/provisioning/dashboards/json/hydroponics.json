        {
          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          },
          "rawSql": "SELECT $__time(date_trunc('day', ts AT TIME ZONE 'America/Denver')::timestamptz),\n  ROUND(AVG(hydro_water_temp_f)::numeric, 1) AS \"Avg\",\n  ROUND(MIN(hydro_water_temp_f)::numeric, 1) AS \"Min\",\n  ROUND(MAX(hydro_water_temp_f)::numeric, 1) AS \"Max\"\nFROM climate\nWHERE $__timeFilter(ts) AND hydro_water_temp_f IS NOT NULL\nGROUP BY 1 ORDER BY 1",
