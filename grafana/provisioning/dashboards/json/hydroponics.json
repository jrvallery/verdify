    {
      "id": 6,
      "type": "timeseries",
      "title": "EC & TDS",
      "description": "Nutrient concentration over time. Green band = target EC range (800-1600 \u00b5S/cm). Rising EC = evaporation concentrating nutrients. Falling EC = plants consuming faster than you're dosing.",
      "datasource": {
        "uid": "verdify-tsdb",
        "type": "grafana-postgresql-datasource"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "targets": [
        {
          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          },
          "rawSql": "SELECT $__time(ts), hydro_ec_us_cm AS \"EC (\u00b5S/cm)\"\nFROM climate WHERE $__timeFilter(ts) AND hydro_ec_us_cm IS NOT NULL ORDER BY ts",
          "format": "time_series",
          "refId": "A"
        },
        {
          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          },
          "rawSql": "SELECT $__time(ts), hydro_tds_ppm AS \"TDS (ppm)\"\nFROM climate WHERE $__timeFilter(ts) AND hydro_tds_ppm IS NOT NULL ORDER BY ts",
          "format": "time_series",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0,
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth"
          },
          "unit": "currencyUSD"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "EC (\u00b5S/cm)"
