    {
      "id": 9,
      "type": "timeseries",
      "title": "Daily Water Temp Range",
      "description": "Min/max/avg water temperature per day. Large daily swings stress roots. Target: <5\u00b0F daily swing.",
      "datasource": {
        "uid": "verdify-tsdb",
        "type": "grafana-postgresql-datasource"
      },
      "gridPos": {
