    {
      "id": 910,
      "type": "table",
      "title": "Latest Hydro Reading",
      "gridPos": {
        "h": 5,
        "w": 24,
        "x": 0,
        "y": 50
      },
      "datasource": {
        "uid": "verdify-tsdb",
        "type": "grafana-postgresql-datasource"
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "countRows": false,
          "fields": ""
        }
      },
      "targets": [
        {
          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          },
          "rawSql": "SELECT\n  to_char(ts AT TIME ZONE 'America/Denver', 'MM/DD HH24:MI') AS \"Sample MDT\",\n  concat('pH ', ph, ' / EC ', ec_us_cm, ' / TDS ', tds_ppm) AS \"Chemistry\",\n  water_temp_f AS \"Water F\",\n  battery_pct AS \"Battery %\",\n  CASE\n    WHEN ph_in_range AND ec_in_range AND temp_in_range AND battery_ok THEN 'OK'\n    ELSE concat_ws(', ',\n      CASE WHEN NOT ph_in_range THEN 'pH' END,\n      CASE WHEN NOT ec_in_range THEN 'EC' END,\n      CASE WHEN NOT temp_in_range THEN 'temp' END,\n      CASE WHEN NOT battery_ok THEN 'battery' END\n    )\n  END AS \"Attention\"\nFROM v_hydro_status",
          "format": "table",
          "refId": "A"
        }
      ],
      "description": "Shows the latest hydroponic water-quality and system readings.",
