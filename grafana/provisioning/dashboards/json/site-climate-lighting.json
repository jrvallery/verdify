          "rawSql": "SELECT $__time(ts), CASE WHEN state THEN 'ON' ELSE 'OFF' END AS \"Grow Light Main\"\nFROM equipment_state WHERE equipment = 'grow_light_main' AND $__timeFilter(ts) ORDER BY ts",
          "refId": "A"
