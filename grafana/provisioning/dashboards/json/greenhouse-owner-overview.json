        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "verdify-tsdb"
          },
          "format": "table",
          "rawSql": "SELECT equipment, CASE WHEN state THEN 'ON' ELSE 'OFF' END AS status,\n  to_char(since AT TIME ZONE 'America/Denver', 'HH:MI AM') AS since,\n  ROUND(seconds_ago / 60.0) AS min_ago\nFROM v_equipment_now\nWHERE equipment IN ('heat1','heat2','fan1','fan2','fog','vent','mister_south','mister_west','mister_center','grow_light_main','grow_light_grow','drip_wall','drip_center')\nORDER BY state DESC, equipment",
          "refId": "A"
        }
      ],
      "title": "Equipment Running Now",
      "type": "table",
      "description": "Shows the current state of key greenhouse equipment.",
      "fieldConfig": {
        "defaults": {
          "custom": {}
        }
      }
