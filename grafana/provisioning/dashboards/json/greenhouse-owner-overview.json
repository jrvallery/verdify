          "format": "table",
          "rawSql": "SELECT to_char(ts AT TIME ZONE 'America/Denver', 'MM/DD HH:MI') AS opened,\n  alert_type, severity, message\nFROM alert_log WHERE disposition = 'open'\nORDER BY severity DESC, ts DESC LIMIT 10",
          "refId": "A"
        }
      ],
      "title": "Open Alerts",
      "type": "table",
      "description": "Shows current or recent alerts that need attention.",
