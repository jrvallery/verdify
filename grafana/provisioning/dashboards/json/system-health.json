          "rawSql": "SELECT\n  time_bucket('5m', ts) AS time,\n  100.0 * count(*) FILTER (WHERE temp_avg IS NULL) / NULLIF(count(*), 0) AS \"NULL %\"\nFROM climate\nWHERE $__timeFilter(ts)\nGROUP BY 1 ORDER BY 1",
