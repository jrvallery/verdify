      "targets": [
        {
          "datasource": {
            "uid": "verdify-tsdb"
          },
          "format": "time_series",
          "rawSql": "SELECT time_bucket('30 minutes', e.ts) AS time, round(avg(watts_total)::numeric, 0) AS \"Greenhouse (W)\" FROM energy e WHERE $__timeFilter(e.ts) GROUP BY 1 ORDER BY 1",
          "refId": "A"
        },
