{
  "panels": [
    {
      "description": "% of greenhouse electricity consumed during solar hours (8AM-5PM)",
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "thresholds": {
            "steps": [
              {
                "color": "orange",
                "value": null
              },
              {
                "color": "green",
                "value": 50
              }
            ]
          },
          "unit": "percent",
          "custom": {}
        }
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "targets": [
        {
          "datasource": {
            "uid": "verdify-tsdb"
          },
          "format": "table",
          "rawSql": "WITH h AS (SELECT extract(hour from ts AT TIME ZONE 'America/Denver')::int as hr, avg(watts_total)::numeric as w FROM energy WHERE $__timeFilter(ts) GROUP BY 1) SELECT now() as time, round(sum(CASE WHEN hr BETWEEN 8 AND 17 THEN w ELSE 0 END)/NULLIF(sum(w),0)*100, 1) as value FROM h"
        }
      ],
      "title": "Solar Aligned",
      "type": "stat",
      "options": {}
    },
    {
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1500
              },
              {
                "color": "red",
                "value": 3000
              }
            ]
          },
          "unit": "watt",
          "custom": {}
        }
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 0
      },
      "id": 2,
      "targets": [
        {
          "datasource": {
            "uid": "verdify-tsdb"
          },
          "format": "table",
          "rawSql": "SELECT now() as time, round(avg(watts_total)::numeric, 0) as value FROM energy WHERE $__timeFilter(ts) AND extract(hour from ts AT TIME ZONE 'America/Denver') BETWEEN 8 AND 17"
        }
      ],
      "title": "Avg Watts (Daytime)",
      "type": "stat",
      "description": "Shows average greenhouse power draw during daytime hours.",
      "options": {}
    },
    {
      "fieldConfig": {
