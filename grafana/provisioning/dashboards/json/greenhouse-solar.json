          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 80
              },
              {
                "color": "green",
                "value": 100
              }
            ]
          },
          "unit": "percent",
          "custom": {}
        }
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 0
      },
      "id": 5,
      "targets": [
        {
          "datasource": {
            "uid": "verdify-tsdb"
          },
          "format": "table",
          "rawSql": "SELECT now() as time, round((13.5 / NULLIF(avg(watts_total)::numeric * 14 / 1000, 0) * 100)::numeric, 0) as value FROM energy WHERE $__timeFilter(ts) AND extract(hour from ts AT TIME ZONE 'America/Denver') NOT BETWEEN 8 AND 17"
        }
      ],
      "title": "Powerwall Coverage",
