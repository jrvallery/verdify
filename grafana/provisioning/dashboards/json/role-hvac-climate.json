    {
      "id": 8,
      "type": "timeseries",
      "title": "VPD vs Setpoints",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "targets": [
        {
          "rawSql": "SELECT $__time(ts), vpd_avg AS \"VPD\" FROM climate WHERE $__timeFilter(ts) AND vpd_avg IS NOT NULL ORDER BY ts",
          "refId": "A",
          "format": "time_series",
          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          }
        },
        {
          "rawSql": "SELECT time_bucket_gapfill('1 hour', ts, start => $__timeFrom(), finish => now()) AS time, locf(last(value, ts)) AS \"Setpoint High\" FROM setpoint_changes WHERE parameter = 'vpd_high' AND source = 'band' AND (expired_at IS NULL OR expired_at > ts) AND value > 0 AND $__timeFilter(ts) GROUP BY 1 ORDER BY 1",
          "refId": "B",
          "format": "time_series",
          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          }
        },
        {
          "rawSql": "SELECT time_bucket_gapfill('1 hour', ts, start => $__timeFrom(), finish => now()) AS time, locf(last(value, ts)) AS \"Setpoint Low\" FROM setpoint_changes WHERE parameter = 'vpd_low' AND source = 'band' AND (expired_at IS NULL OR expired_at > ts) AND $__timeFilter(ts) GROUP BY 1 ORDER BY 1",
          "refId": "C",
          "format": "time_series",
          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "pressurekpa",
          "custom": {
            "lineWidth": 2,
            "spanNulls": true,
            "lineInterpolation": "linear",
            "showPoints": "never",
            "fillOpacity": 10,
            "axisLabel": "kPa"
          }
        },
        "overrides": [
          {
            "matcher": {
