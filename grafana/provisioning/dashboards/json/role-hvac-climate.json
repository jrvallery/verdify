        {
          "rawSql": "SELECT time_bucket_gapfill('1 hour', ts, start => $__timeFrom(), finish => now()) AS time, locf(last(value, ts)) AS \"Setpoint High\" FROM setpoint_changes WHERE parameter = 'vpd_high' AND value > 0 AND $__timeFilter(ts) GROUP BY 1 ORDER BY 1",
