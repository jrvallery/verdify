                    6,
                    4
                  ]
                }
              },
              {
                "id": "custom.lineInterpolation",
                "value": "stepBefore"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Setpoint Low"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#42A5F5",
