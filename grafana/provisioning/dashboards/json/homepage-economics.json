        "w": 6,
        "x": 18,
        "y": 4
      },
      "targets": [
        {
          "rawSql": "SELECT ROUND(AVG(cost_total)::numeric, 2) AS \"Avg\" FROM daily_summary WHERE date > (CURRENT_DATE - '${period}'::interval) AND cost_total > 0",
          "refId": "A",
          "format": "table",
          "datasource": {
            "uid": "verdify-tsdb",
