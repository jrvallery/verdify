{
  "uid": "greenhouse-homepage-economics",
  "title": "Greenhouse: Homepage Economics",
  "description": "Embeddable cost panels for verdify.ai homepage \u2014 supports period variable for time range",
  "tags": [
    "economics",
    "greenhouse",
    "homepage",
    "standardized"
  ],
  "timezone": "America/Denver",
  "editable": false,
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "refresh": "5m",
  "templating": {
    "list": [
      {
        "name": "period",
        "type": "custom",
        "label": "Time Period",
        "current": {
          "text": "30d",
          "value": "30d"
        },
        "options": [
          {
            "text": "7d",
            "value": "7d",
            "selected": false
          },
          {
            "text": "30d",
            "value": "30d",
            "selected": true
          },
          {
            "text": "90d",
            "value": "90d",
            "selected": false
          },
          {
            "text": "180d",
            "value": "180d",
            "selected": false
          }
        ],
        "query": "7d,30d,90d,180d"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Cost",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "rawSql": "SELECT SUM(cost_total)::numeric(10,2) AS \"Total\" FROM daily_summary WHERE date > (CURRENT_DATE - '${period}'::interval)",
          "refId": "A",
          "format": "table",
          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 100
              },
              {
                "color": "red",
                "value": 300
              }
            ]
          },
          "custom": {}
        },
        "overrides": []
      },
      "description": "Shows total operating cost for the selected period.",
      "options": {}
    },
    {
