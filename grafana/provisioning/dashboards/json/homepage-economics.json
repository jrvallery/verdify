    {
      "id": 10,
      "type": "timeseries",
      "title": "Daily Cost by Type",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "rawSql": "SELECT $__time(date::timestamptz), cost_electric AS \"Electric\" FROM daily_summary WHERE date > (CURRENT_DATE - '${period}'::interval) AND cost_total > 0 ORDER BY date",
          "refId": "A",
          "format": "time_series",
          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          }
        },
        {
          "rawSql": "SELECT $__time(date::timestamptz), cost_gas AS \"Gas\" FROM daily_summary WHERE date > (CURRENT_DATE - '${period}'::interval) AND cost_total > 0 ORDER BY date",
          "refId": "B",
          "format": "time_series",
          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          }
        },
        {
          "rawSql": "SELECT $__time(date::timestamptz), cost_water AS \"Water\" FROM daily_summary WHERE date > (CURRENT_DATE - '${period}'::interval) AND cost_total > 0 ORDER BY date",
          "refId": "C",
          "format": "time_series",
