            "uid": "verdify-tsdb"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT ts AS time, outdoor_temp_f AS \"Outdoor\"\nFROM climate\nWHERE $__timeFilter(ts) AND ts <= now() AND outdoor_temp_f IS NOT NULL\nORDER BY ts",
          "refId": "D",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
