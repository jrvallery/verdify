{
  "uid": "greenhouse-data-trust-ledger",
  "title": "Greenhouse: Data Trust Ledger",
  "description": "Freshness, coverage, lifecycle, water, energy, forecast, crop, archive, and instrumentation trust checks.",
  "tags": [
    "greenhouse",
    "data-quality",
    "trust",
    "standardized"
  ],
  "timezone": "America/Denver",
  "editable": false,
  "time": {
    "from": "now-14d",
    "to": "now"
  },
  "refresh": "5m",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Failing Checks",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "rawSql": "SELECT count(*) FROM v_data_trust_ledger WHERE status = 'fail'",
          "refId": "A",
          "format": "table",
          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Warning Checks",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "rawSql": "SELECT count(*) FROM v_data_trust_ledger WHERE status = 'warn'",
          "refId": "A",
          "format": "table",
          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "table",
      "title": "Trust Ledger",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "rawSql": "SELECT check_name AS \"Check\", status AS \"Status\", metric_value AS \"Value\", threshold_value AS \"Threshold\", details AS \"Details\" FROM v_data_trust_ledger ORDER BY CASE status WHEN 'fail' THEN 1 WHEN 'warn' THEN 2 ELSE 3 END, check_name",
          "refId": "A",
          "format": "table",
          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          }
        }
      ]
    },
    {
      "id": 4,
      "type": "table",
      "title": "Instrumentation Readiness",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "targets": [
        {
          "rawSql": "SELECT category AS \"Category\", metric AS \"Metric\", current_status AS \"Status\", readiness_status AS \"Readiness\", blocks_story AS \"Story Blocked\", recommended_source AS \"Recommended Source\" FROM v_instrumentation_readiness ORDER BY priority, category",
          "refId": "A",
          "format": "table",
          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          }
        }
      ]
    },
    {
      "id": 5,
      "type": "table",
      "title": "Daily Plan Archive Self-Check",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "targets": [
        {
          "rawSql": "SELECT date AS \"Date\", status AS \"Status\", generated_plan_count AS \"Generated Plans\", db_plan_count AS \"DB Plans\", generated_at AS \"Generated At\" FROM v_daily_plan_archive_self_check WHERE date >= (now() AT TIME ZONE 'America/Denver')::date - 14 ORDER BY date DESC",
          "refId": "A",
          "format": "table",
          "datasource": {
            "uid": "verdify-tsdb",
            "type": "grafana-postgresql-datasource"
          }
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
